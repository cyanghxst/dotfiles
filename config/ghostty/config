# ----------------------------------------
# test line
# Ghostty Configuration
# ----------------------------------------

# ----------------------------------------
# General
# ----------------------------------------

scrollback-limit = 10485760
confirm-close-surface = false

# ----------------------------------------
# Pointers
# ----------------------------------------

# Mouse
mouse-hide-while-typing = true

# Cursor
cursor-style = "block"
cursor-style-blink = false
shell-integration-features = "no-cursor"

# ----------------------------------------
# Appearance
# ----------------------------------------

# Theme
theme = "tokyonight"
background = 16151d

# Fonts
# font-size = 15
font-size = 14
font-family = "JetBrainsMono Nerd Font Mono"

# Misc.
adjust-underline-position = 4
window-colorspace = "display-p3"

# Cursor
# custom-shader = shaders/cursor_warp.glsl
# custom-shader = shaders/ripple_rectangle_cursor.glsl

# ----------------------------------------
# Window
# ----------------------------------------

# Desktop
# window-height = 42
# window-width = 173
# window-padding-x = 27
# window-padding-y = 15
# window-padding-balance = true

# Laptop
window-height = 41
window-width = 148
window-padding-x = 28
window-padding-y = 14

# Laptop 2
# window-height = 45
# window-width = 163
# window-padding-x = 28
# window-padding-y = 14

# Misc.
window-save-state = never
window-padding-color = "background"

# ----------------------------------------
# Title bar
# ----------------------------------------

title = " "
macos-titlebar-style = "tabs"

# ----------------------------------------
# Dock icon
# ----------------------------------------

